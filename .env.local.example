# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Server-only: für zuverlässiges Speichern von Umfrageantworten (API Route /api/responses)
# Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin Password (change this!)
NEXT_PUBLIC_ADMIN_PASSWORD=orendt2026

# --- KI-Zusammenfassung (nur Server / API — niemals NEXT_PUBLIC_ setzen) ---
# Claude wird zuerst versucht; bei Fehler oder Timeout folgt OpenAI.
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...

# Optional: Modell-IDs (Standard: claude-sonnet-4-5 + gpt-4o)
# ANTHROPIC_MODEL=claude-sonnet-4-5
# OPENAI_MODEL=gpt-4o
